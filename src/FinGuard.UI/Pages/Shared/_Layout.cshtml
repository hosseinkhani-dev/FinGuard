<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FinGuard.UI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FinGuard.UI.styles.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-md navbar-light bg-white border-bottom shadow-sm py-2.5">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary d-flex align-items-center gap-2" asp-area="" asp-page="/Index">
                    <i class="bi bi-shield-lock-fill"></i> FinGuard
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0 gap-1">
                        <li class="nav-item">
                            <a class="nav-link text-secondary fw-medium px-3" asp-area="" asp-page="/Index">Home</a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-secondary fw-medium px-3" asp-area="" asp-page="/Users/Index">User Management</a>
                            </li>
                        }

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-secondary fw-medium px-3" asp-area="" asp-page="/TransactionFiles/Index">Transaction File</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-secondary fw-medium px-3" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-3 border-start ps-md-4 ms-md-2 mt-3 mt-md-0 border-light">
                        @if (User.Identity?.IsAuthenticated != true)
                        {
                           @*  <a class="btn btn-primary btn-sm px-3 fw-medium d-flex align-items-center gap-2 rounded-2" asp-area="" asp-page="/Auth/Login">
                                <i class="bi bi-box-arrow-in-right"></i> Sign In
                            </a> *@
                        }
                        else
                        {
                            <div class="dropdown">
                                <button class="btn btn-light btn-sm dropdown-toggle d-flex align-items-center gap-3 border px-2 py-1 rounded-2" type="button" id="userMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle text-primary fs-5"></i>
                                    <span class="fw-medium text-dark">@(User.Identity.Name ?? "Account")</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-light mt-2" aria-labelledby="userMenuButton">
                                    @* <li>
                                        <h6 class="dropdown-header small text-muted">Manage Session</h6>
                                    </li> *@
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <button type="button" class="dropdown-item text-danger d-flex align-items-center gap-1 px-2" data-bs-toggle="modal" data-bs-target="#logoutModal">
                                            <i class="bi bi-power"></i> Sign Out
                                        </button>
                                    </li>
                                </ul>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5 pt-3">
            @RenderBody()
        </main>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="modal fade" id="logoutModal" tabindex="-1" aria-labelledby="logoutModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-sm">
                <div class="modal-content border-0 shadow">
                    <div class="modal-body p-4 text-center">
                        <i class="bi bi-exclamation-circle text-warning display-6 mb-3 d-block"></i>
                        <h5 class="modal-title fw-bold text-dark mb-2" id="logoutModalLabel">Sign Out?</h5>
                        <p class="text-secondary small mb-4">Are you sure you want to end your active session?</p>

                        <div class="d-flex gap-2 justify-content-center">
                            <button type="button" class="btn btn-light btn-sm px-4 fw-medium border" data-bs-dismiss="modal">Cancel</button>
                            <form class="m-0" asp-area="" asp-page="/Auth/Logout" method="post">
                                <button type="submit" class="btn btn-danger btn-sm px-4 fw-medium">Sign Out</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <footer class="border-top footer text-muted bg-white py-1 position-fixed bottom-0 w-100 shadow-sm">
        <div class="container small">
            &copy; 2026 - FinGuard - <a class="text-decoration-none" asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>