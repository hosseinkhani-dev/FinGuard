@page
@model FinGuard.UI.Pages.Users.IndexModel
@{
    ViewData["Title"] = "User Dashboard";
}

<div class="container-fluid py-4">
    @* Validation Summary for API / ModelState errors *@
    <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm mb-4" role="alert"></div>

    @* Dashboard Header Section *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">User Management</h1>
            <p class="text-muted small mb-0">View, search, and manage user system access.</p>
        </div>
        <a asp-page="./Create" class="btn btn-primary shadow-sm d-flex align-items-center gap-2">
            <i class="bi bi-person-plus-fill"></i> Create New User
        </a>
    </div>

    @* Unified Filter & Search Card *@
    <div class="card border-0 shadow-sm mb-4 bg-white rounded">
        <div class="card-body p-4">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label asp-for="SearchUserName" class="form-label fw-bold text-secondary small">Username</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-person"></i></span>
                        <input asp-for="SearchUserName" class="form-control bg-light border-start-0" placeholder="Search by username..." />
                    </div>
                </div>

                <div class="col-md-4">
                    <label asp-for="SearchEmail" class="form-label fw-bold text-secondary small">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-envelope"></i></span>
                        <input asp-for="SearchEmail" class="form-control bg-light border-start-0" placeholder="Search by email..." />
                    </div>
                </div>

                <div class="col-md-2">
                    <label asp-for="SearchIsActive" class="form-label fw-bold text-secondary small">Status</label>
                    <select asp-for="SearchIsActive" class="form-select bg-light">
                        <option value="">All Statuses</option>
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>

                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100 shadow-sm">
                        <i class="bi bi-search me-1"></i> Filter
                    </button>
                    <a asp-page="./Index" class="btn btn-outline-secondary w-100" title="Clear Filters">
                        Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    @* Users Table Card *@
    <div class="card border-0 shadow-sm bg-white rounded">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary small text-uppercase">
                        <tr>
                            <th class="ps-4 py-3" style="width: 35%;">User Details</th>
                            <th class="py-3" style="width: 15%;">Status</th>
                            <th class="pe-4 py-3 text-end" style="width: 15%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Users != null && Model.Users.Any())
                        {
                            foreach (var user in Model.Users)
                            {
                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-placeholder rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold me-3" style="width: 40px; height: 40px;">
                                                @user.UserName.Substring(0, Math.Min(2, user.UserName.Length)).ToUpper()
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@user.UserName</div>
                                                <div class="text-muted text-truncate small" style="max-width: 200px;">Email: @user.Email</div>
                                            </div>
                                        </div>
                                    </td>

                                    <td class="py-3">
                                        @if (user.ActiveStatus == "Active")
                                        {
                                            <span class="badge bg-success-subtle text-success px-2.5 py-1.5 rounded-pill fw-medium">
                                                <i class="bi bi-circle-fill me-1 small"></i> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger px-2.5 py-1.5 rounded-pill fw-medium">
                                                <i class="bi bi-circle-fill me-1 small"></i> Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="pe-4 py-3 text-end">
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-sm rounded-circle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                                <li>
                                                    <a class="dropdown-item px-3 py-2" href="#">
                                                        <i class="bi bi-pencil me-2 text-muted"></i> Edit User
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <form method="post" asp-page-handler="ToggleStatus" asp-route-id="@user.Id" asp-route-currentStatus="@user.ActiveStatus" class="m-0 p-0">
                                                        <button type="button" onclick="this.closest('form').submit();" class="dropdown-item text-danger px-3 py-2 btn btn-sm w-100 text-start border-0 bg-transparent" style="box-shadow: none;">
                                                            <i class="bi bi-power me-2"></i> Toggle Status
                                                        </button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <div class="mb-2"><i class="bi bi-people text-light" style="font-size: 3rem;"></i></div>
                                    <p class="mb-0 fw-medium">No users match the evaluated criteria.</p>
                                    <p class="text-muted small">Try adjusting your filters or search terms.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table > :not(caption) > * > * {
        border-bottom-color: #f2f4f7;
    }

    .bg-success-subtle {
        background-color: #d1e7dd !important;
    }

    .bg-danger-subtle {
        background-color: #f8d7da !important;
    }

    .dropdown-item:hover {
        background-color: #f8f9fa;
    }
</style>